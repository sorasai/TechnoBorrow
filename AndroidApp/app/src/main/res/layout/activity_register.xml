<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".features.auth.ui.RegisterActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Logo & Brand Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:src="@drawable/technoborrow_logo" />

                <com.example.technoborrowapp.core.ui.GradientTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TechnoBorrow"
                    android:textColor="@color/primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Create Account"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp"
                android:text="Join the TechnoBorrow community"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

            <!-- Fields -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="Full Name"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFullName"
                style="@style/AuthInputStyle"
                android:hint="Enter your full name"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="CIT-U Email"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEmail"
                style="@style/AuthInputStyle"
                android:hint="e.g. firstname.lastname@cit.edu"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="Password"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPassword"
                style="@style/AuthInputStyle"
                android:hint="Create a password"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="Confirm Password"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etConfirmPassword"
                style="@style/AuthInputStyle"
                android:hint="Re-enter your password"
                android:inputType="textPassword"
                android:layout_marginBottom="24dp" />

            <CheckBox
                android:id="@+id/cbTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:buttonTint="@color/primary"
                android:text="By creating an account, you agree to the Terms and Conditions"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/AuthButtonStyle"
                android:text="Register" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="Already have an account? Login"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>